# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Configuration
# For MongoDB Atlas (Cloud):
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/peerly?retryWrites=true&w=majority
# 
# For Local MongoDB:
# MONGODB_URI=mongodb://localhost:27017/peerly
#
# IMPORTANT: 
# - Replace <username> and <password> with your Atlas database user credentials
# - URL-encode special characters in password (@ → %40, # → %23, etc.)
# - Add database name (/peerly) before the ? in connection string
# - No quotes, no spaces around =
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/peerly?retryWrites=true&w=majority

# JWT Configuration
# Generate a secure secret using: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Or use: openssl rand -hex 64
# IMPORTANT: Use a strong random string (at least 32 characters) and keep it secret!
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d

# Email / SMTP Configuration (for OTP / verification links)
# If not set, verification links will be logged to the console for local testing.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@spit.ac.in
# SMTP_PASS=your_email_app_password
# EMAIL_FROM="MentorLink <no-reply@spit.ac.in>"

# Allowed Institute Email Domains (comma-separated)
ALLOWED_DOMAINS=spit.ac.in,yourinstitute.ac.in
